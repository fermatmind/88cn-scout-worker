{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://88cn.example/contracts/canonical-candidate-contract.json",
  "title": "Canonical Candidate Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "candidate_id",
    "project_name",
    "canonical_slug",
    "evidence"
  ],
  "properties": {
    "candidate_id": {
      "type": "string",
      "minLength": 1
    },
    "project_name": {
      "type": "string",
      "minLength": 1
    },
    "canonical_slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "kind",
          "url"
        ],
        "properties": {
          "kind": {
            "type": "string",
            "enum": [
              "official_site",
              "public_repo",
              "public_docs",
              "public_launch"
            ]
          },
          "url": {
            "type": "string",
            "format": "uri"
          }
        }
      }
    }
  }
}
