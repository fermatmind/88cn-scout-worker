{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://88cn.example/contracts/discovery-hint-contract.json",
  "title": "Discovery Hint Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "project_name",
    "source_url",
    "official_website_url",
    "github_url",
    "docs_url",
    "source_type",
    "suggested_category",
    "discovered_at",
    "confidence",
    "reason_codes",
    "auto_publish"
  ],
  "properties": {
    "project_name": {
      "type": "string",
      "minLength": 1
    },
    "source_url": {
      "type": "string",
      "format": "uri"
    },
    "official_website_url": {
      "type": ["string", "null"],
      "format": "uri"
    },
    "github_url": {
      "type": ["string", "null"],
      "format": "uri"
    },
    "docs_url": {
      "type": ["string", "null"],
      "format": "uri"
    },
    "source_type": {
      "type": "string",
      "enum": [
        "github",
        "launch",
        "directory-hints",
        "chinese-outbound",
        "official-site",
        "manual-submit"
      ]
    },
    "suggested_category": {
      "type": ["string", "null"]
    },
    "discovered_at": {
      "type": "string"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "reason_codes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "auto_publish": {
      "const": false
    }
  }
}
