{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://88cn.example/contracts/http-audit-input-contract.json",
  "title": "HTTP Audit Input Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "url"
  ],
  "properties": {
    "url": {
      "type": "string",
      "format": "uri"
    },
    "domain_cooldown_ms": {
      "type": "integer",
      "minimum": 0
    },
    "checked_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
