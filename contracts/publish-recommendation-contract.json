{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://88cn.example/contracts/publish-recommendation-contract.json",
  "title": "Publish Recommendation Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "project_name",
    "slug_candidate",
    "recommendation",
    "reason_codes",
    "missing_fields",
    "risk_flags",
    "human_review_notes",
    "no_public_claim",
    "published",
    "auto_publish",
    "public_projection"
  ],
  "properties": {
    "project_name": {
      "type": "string",
      "minLength": 1
    },
    "slug_candidate": {
      "type": "string",
      "minLength": 1
    },
    "recommendation": {
      "type": "string",
      "enum": [
        "recommend_publish",
        "recommend_review",
        "recommend_quarantine",
        "recommend_reject",
        "recommend_recheck"
      ]
    },
    "reason_codes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "missing_fields": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risk_flags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "human_review_notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "no_public_claim": {
      "type": "boolean",
      "const": true
    },
    "published": {
      "type": "boolean",
      "const": false
    },
    "auto_publish": {
      "type": "boolean",
      "const": false
    },
    "public_projection": {
      "type": "boolean",
      "const": false
    }
  }
}
